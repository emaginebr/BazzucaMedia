{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Schedule": {
    "Cron": "* 0/5 * * * *",
    "CronDaily": "0 0 0 * * *"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest"
  },
  "Queues": {
    "LinkedIn": {
      "Msg": "bazzuca.linkedin.msg",
      "Retry": "bazzuca.linkedin.retry",
      "Error": "bazzuca.linkedin.error",
      "MaxRetryCount": 3,
      "RetryTtlMs": 600000
    }
  },
  "LinkedIn": {
    "BrowserDataPath": "./playwright-data"
  }
}
