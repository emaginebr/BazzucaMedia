# Bazzuca Production Environment - SECRETS ONLY
# Copy this file to .env.prod and update with production values

# Tenant: bazzuca
BAZZUCA_CONNECTION_STRING=Host=bazzuca-postgres;Port=5432;Database=bazzuca_db;Username=bazzuca_user;Password=<STRONG_PASSWORD>
BAZZUCA_JWT_SECRET=<STRONG_JWT_SECRET_MIN_64_CHARS>

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=<STRONG_RABBITMQ_PASSWORD>
