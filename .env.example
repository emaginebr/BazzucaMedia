# Bazzuca Docker Environment Configuration
# Copy this file to .env and update with your values

# ==========================================
# PostgreSQL Database Configuration
# ==========================================
POSTGRES_DB=bazzuca_db
POSTGRES_USER=bazzuca_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5434

# ==========================================
# Multi-Tenant Configuration
# ==========================================
DEFAULT_TENANT_ID=bazzuca

# Tenant: bazzuca
BAZZUCA_CONNECTION_STRING=Host=bazzuca-postgres;Port=5432;Database=bazzuca_db;Username=bazzuca_user;Password=your_secure_password_here
BAZZUCA_JWT_SECRET=your_bazzuca_jwt_secret_key_min_32_chars_recommended_64_chars


# ==========================================
# Bazzuca API Configuration
# ==========================================
API_HTTP_PORT=5010
API_HTTPS_PORT=5011

# ==========================================
# Bazzuca App Configuration
# ==========================================
BAZZUCA_APP_PORT=5012
VITE_API_URL=http://localhost:5004
VITE_BAZZUCA_API_URL=https://localhost:5011
NODE_ENV=development

# ==========================================
# ASP.NET Core Environment
# ==========================================
# Options: Development, Docker, Production
ASPNETCORE_ENVIRONMENT=Docker

# ==========================================
# SSL Certificate Configuration (optional)
# ==========================================
# Leave empty to run HTTP only
CERTIFICATE_PATH=/app/certs/certificate.pfx
CERTIFICATE_PASSWORD=your_certificate_password
CERTIFICATE_DIRECTORY=./certs
