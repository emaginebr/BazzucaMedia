# Bazzuca Docker Environment Configuration
# Copy this file to .env and update with your values

# ==========================================
# PostgreSQL Database Configuration
# ==========================================
POSTGRES_DB=bazzuca_db
POSTGRES_USER=bazzuca_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_PORT=5434

# ==========================================
# Bazzuca Tenant Configuration
# ==========================================
JWT_SECRET=your_jwt_secret_key_min_32_chars_recommended_64_chars

# ==========================================
# Bazzuca API Configuration
# ==========================================
API_HTTP_PORT=5010

# ==========================================
# RabbitMQ Configuration
# ==========================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
